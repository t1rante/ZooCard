# Valores de referência para as variáveis de ambiente que o backend lê
# (veja backend/src/main/resources/application.properties). Exporte-as no
# shell antes de rodar `./mvnw spring-boot:run`, ou configure-as na sua IDE
# (veja .vscode/launch.json). Os valores padrão já funcionam sem editar nada.

# Senha do usuário "postgres" local — não precisa ser forte para uso
# local/acadêmico.
DB_PASSWORD=postgres

# Segredo usado para assinar os tokens JWT. Troque por um valor aleatório antes
# de qualquer uso além de demo/local.
JWT_SECRET=dev-secret-trocar-em-producao
